<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Express Pro</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #2527c7;
            --primary-hover: #2c25b662;
            --success: #10b981;
            --success-hover: #059669;
            --dark: #1e293b;
            --text-main: #334155;
            --text-muted: #64748b;
            --bg-body: #f1f5f9;
            --shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.637), 0 8px 10px -6px rgba(0, 0, 0, 0.336);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 850px;
            background: rgba(82, 78, 78, 0.205);
            padding: 40px;
            border-radius: 20px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(10px);
        }

        header {
            margin-bottom: 35px;
            border-left: 5px solid var(--primary);
            padding-left: 20px;
        }

        header h1 {
            font-size: 1.8rem;
            color: var(--dark);
            letter-spacing: -0.5px;
        }

        header p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 30px;
        }

        h3 {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: var(--text-muted);
            margin-bottom: 15px;
        }

        .form-box label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 5px;
            color: var(--dark);
        }

        input {
            width: 100%;
            padding: 12px 15px;
            margin-bottom: 18px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-family: inherit;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }

        button {
            width: 100%;
            padding: 14px;
            cursor: pointer;
            border: none;
            border-radius: 12px;
            font-family: inherit;
            font-weight: 700;
            font-size: 0.95rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #add-item {
            background-color: var(--primary);
            color: rgb(243, 243, 243);
        }

        #add-item:hover {
            background-color: whitesmoke;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(28, 30, 153, 0.87);
            color: rgba(0, 0, 0, 0.76);
        }

        .preview-box {
            background: linear-gradient(90deg,rgb(19, 19, 26) 0%, rgba(9, 9, 121, 1) 35%, rgb(0, 0, 0) 100%);
            color: whitesmoke;
            width: 100%;
            margin-top: 129px;
            padding: 40px;
            border-radius: 18px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        .preview-box::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 100px;
            height: 100px;
            background: rgba(255,255,255,0.05);
            background: linear-gradient(90deg,rgba(2, 0, 36, 1) 0%, rgba(9, 9, 121, 1) 35%, rgba(0, 212, 255, 1) 100%);
            border-radius: 50%;
        }

        #display-info p {
            margin-bottom: 8px;
            font-size: 0.85rem;
            color: #94a3b8;
        }

        #display-info span {
            display: block;
            color: whitesmoke;
            font-size: 1.1rem;
            font-weight: 600;
            margin-top: 4px;
        }

        #view-total {
            font-size: 1.8rem;
            font-weight: 800;
            color: whitesmoke;
            margin: 5px 0 15px 0;
            display: block;
        }

        .btn-success {
            background: var(--success);
            color: white;
        }

        .btn-success:hover {
            background: var(--success-hover);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(34, 172, 126, 0.438);
        }

        @media (max-width: 768px) {
            .grid { grid-template-columns: 1fr; }
            .container { padding: 25px; }
        }
    </style>
</head>
<body>
   <main class="container">
    <header>
        <h1 style="color: #051b96;">Invoice Pro</h1>
        <p>Generate professional PDF quotes in seconds.</p>
    </header>

    <div class="grid">
        <section class="form-box">
            <h3>🏢 Business Details</h3>
                <label>Company Name</label>
                <input type="text" id="myCompany" placeholder="e.g. Denker Tech Solutions">
                <label>Tax ID / Contact Info</label>
                <input type="text" id="companyDetails" placeholder="EIN, Phone or Address">

            <h3>👤 Client Details</h3>
                <label>Client Name</label>
                <input type="text" id="client" placeholder="Customer or Company name">
                <label>Service Description</label>
                <input type="text" id="service" placeholder="e.g. Software Development">

            <div style="display: flex; gap: 15px;">
                <div style="flex: 2;">
                    <label>Unit Price ($)</label>
                    <input type="number" id="valor" placeholder="0,00">
                </div>
                <div style="flex: 1;">
                    <label>Qty</label>
                    <input type="number" id="qtd" value="1">
                </div>
            </div>

            <button id="add-item">Calculate & Preview</button>
        </section>

        <section class="preview-box">
            <div id="display-info">
                <h3>Summary</h3>
                <p>Client: <span id="view-client">Waiting for data...</span></p>
                <p>Service: <span id="view-service">---</span></p>
                <p>TOTAL AMOUNT</p>
                <span id="view-total">$ 0.00</span>
            </div>
            <button id="download-pdf" class="btn-success">Export to PDF</button>
        </section>
    </div>
   </main>

   <script>
        // Inicializa o jsPDF globalmente
        window.jsPDF = window.jspdf.jsPDF;

        const btnAdd = document.getElementById('add-item');
        const btnPdf = document.getElementById('download-pdf');

        btnAdd.addEventListener('click', () => {
            try {
                // Captura os valores dos campos corrigidos
                const client = document.getElementById('client').value.trim();
                const service = document.getElementById('service').value.trim();
                const valor = parseFloat(document.getElementById('valor').value);
                const qtd = parseInt(document.getElementById('qtd').value);

                // Validações
                if (!client) throw new Error("O nome do cliente é obrigatório!");
                if (isNaN(valor) || valor <= 0) throw new Error("O valor deve ser maior que zero!");
                if (isNaN(qtd) || qtd < 1) throw new Error("A quantidade deve ser pelo menos 1!");

                const total = valor * qtd;

                // Atualiza o preview
                document.getElementById('view-client').innerText = client;
                document.getElementById('view-service').innerText = service || "Serviço não especificado";
                document.getElementById('view-total').innerText = `$ ${total.toFixed(2)}`; // Formato americano (ex: 1500.00)

            } catch (err) {
                alert("⚠️ " + err.message);
            }
        });

        btnPdf.addEventListener('click', () => {
            // Verifica se já foi calculado algo
            const client = document.getElementById('view-client').innerText;
            const total = document.getElementById('view-total').innerText;
            const service = document.getElementById('view-service').innerText;

            if (client === "Waiting for data...") {
                alert("Por favor, calcule o valor antes de exportar.");
                return;
            }

            const doc = new jsPDF();

            doc.setFillColor(99, 102, 241);
            doc.rect(0, 0, 210, 40, 'F');
            
            doc.setFont("helvetica", "bold");
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(22);
            doc.text("ORÇAMENTO", 20, 25);
            
            doc.setTextColor(60, 60, 60);
            doc.setFontSize(10);
            doc.text("DADOS DO CLIENTE", 20, 55);
            doc.setFontSize(14);
            doc.setTextColor(0, 0, 0);
            doc.text(client.toUpperCase(), 20, 65);
            
            doc.setDrawColor(230, 230, 230);
            doc.line(20, 75, 190, 75);
            
            doc.setFontSize(10);
            doc.setTextColor(60, 60, 60);
            doc.text("DESCRIÇÃO DO SERVIÇO", 20, 90);
            doc.setFontSize(12);
            doc.setTextColor(0, 0, 0);
            doc.text(service, 20, 100);
            
            doc.setFillColor(245, 245, 245);
            doc.rect(20, 115, 170, 20, 'F');
            doc.setFontSize(14);
            doc.setFont("helvetica", "bold");
            doc.text(`TOTAL: ${total}`, 25, 128);
            
            // Rodapé com data
            doc.setFontSize(9);
            doc.setTextColor(150, 150, 150);
            doc.setFont("helvetica", "normal");
            doc.text(`Documento gerado em: ${new Date().toLocaleString()}`, 20, 150);

            doc.save(`Orcamento_${client}.pdf`);
        });
   </script>
</body>
</html>
